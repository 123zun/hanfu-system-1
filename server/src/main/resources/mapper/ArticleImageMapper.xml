<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.server.article.mapper.ArticleImageMapper">

    <resultMap id="ArticleImageResultMap" type="com.server.article.entity.ArticleImage">
        <id property="id" column="id" />
        <result property="articleId" column="article_id" />
        <result property="imageUrl" column="image_url" />
        <result property="sortOrder" column="sort_order" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <!-- 批量插入 -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO article_image (article_id, image_url, sort_order) VALUES
        <foreach collection="images" item="item" separator=",">
            (#{item.articleId}, #{item.imageUrl}, #{item.sortOrder})
        </foreach>
    </insert>

</mapper>